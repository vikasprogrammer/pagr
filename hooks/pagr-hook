#!/usr/bin/env python3
"""pagr per-machine hook client.

Installed at ~/.claude/pagr-hook and wired into ~/.claude/settings.json so
Claude Code calls it on lifecycle events:

    pagr-hook start | prompt | stop | needs_input | idle | end

It reads the hook JSON from stdin, derives machine name + git branch + Claude's
auto-generated session title (`aiTitle`) + a one-line summary, and POSTs to
$PAGR_URL.

Design rules: never block Claude (3s timeout), never crash a turn (always exit 0),
and use only the Python standard library (no pip install on the agent machine).

Config comes from env (set via the `env` block in settings.json):
    PAGR_URL      e.g. https://pagr.sh   (required)
    PAGR_TOKEN    shared secret -> sent as `Authorization: Bearer`
    PAGR_MACHINE  display name for this machine (default: hostname)
"""
import json
import os
import socket
import subprocess
import sys
import urllib.request

TIMEOUT = 3
SUMMARY_MAX = 220


def read_stdin_json() -> dict:
    try:
        raw = sys.stdin.read()
        return json.loads(raw) if raw.strip() else {}
    except Exception:
        return {}


def read_tail(path: str, max_bytes: int = 262144) -> str:
    """Return the last ~256KB of a (possibly large) transcript file."""
    try:
        with open(path, "rb") as f:
            f.seek(0, os.SEEK_END)
            size = f.tell()
            f.seek(max(0, size - max_bytes))
            return f.read().decode("utf-8", errors="replace")
    except Exception:
        return ""


def block_text(content) -> str:
    """Extract human-readable text from a message `content` (str or block list)."""
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for b in content:
            if isinstance(b, dict) and b.get("type") == "text" and b.get("text"):
                parts.append(b["text"])
            elif isinstance(b, str):
                parts.append(b)
        return "\n".join(parts)
    return ""


def last_message_text(dump: str, role: str) -> str:
    """Last text from a message with the given role ('assistant' or 'user')."""
    for line in reversed(dump.splitlines()):
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except Exception:
            continue  # partial first line from the tail slice, etc.
        msg = obj.get("message") if isinstance(obj.get("message"), dict) else obj
        if (msg.get("role") or obj.get("type")) != role:
            continue
        text = block_text(msg.get("content")).strip()
        if text:
            return text
    return ""


def last_ai_title(dump: str) -> str:
    """Claude's auto-generated session title (last `ai-title` entry)."""
    for line in reversed(dump.splitlines()):
        if '"ai-title"' not in line:
            continue
        try:
            obj = json.loads(line.strip())
        except Exception:
            continue
        if obj.get("type") == "ai-title" and obj.get("aiTitle"):
            return obj["aiTitle"]
    return ""


def git_branch(cwd: str) -> str:
    if not cwd or not os.path.isdir(cwd):
        return ""
    try:
        out = subprocess.run(
            ["git", "-C", cwd, "rev-parse", "--abbrev-ref", "HEAD"],
            capture_output=True, text=True, timeout=1,
        )
        return out.stdout.strip() if out.returncode == 0 else ""
    except Exception:
        return ""


def clean(text: str, limit: int = SUMMARY_MAX) -> str:
    return " ".join((text or "").split())[:limit]


def main() -> int:
    url = os.environ.get("PAGR_URL", "").strip().rstrip("/")
    if not url:
        return 0  # not configured -> no-op

    event = sys.argv[1] if len(sys.argv) > 1 else "prompt"
    data = read_stdin_json()
    cwd = data.get("cwd") or os.getcwd()
    transcript = data.get("transcript_path") or ""
    message = data.get("message") or ""
    dump = read_tail(transcript) if transcript else ""

    if event == "prompt":
        summary = data.get("prompt") or last_message_text(dump, "user")
    elif event in ("stop", "idle", "end"):
        summary = last_message_text(dump, "assistant") or message
    elif event == "needs_input":
        summary = message or last_message_text(dump, "assistant")
    else:  # start
        summary = ""

    payload = {
        "machine": os.environ.get("PAGR_MACHINE") or socket.gethostname().replace(".local", ""),
        "session_id": data.get("session_id") or "unknown",
        "event": event,
        "cwd": cwd,
        "branch": git_branch(cwd),
        "title": clean(last_ai_title(dump), 80),   # Claude's auto session title
        "summary": clean(summary),
        "message": clean(message),
    }

    req = urllib.request.Request(
        url + "/api/event",
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    token = os.environ.get("PAGR_TOKEN", "").strip()
    if token:
        req.add_header("Authorization", "Bearer " + token)
    try:
        urllib.request.urlopen(req, timeout=TIMEOUT).read()
    except Exception:
        pass  # offline / server down -> stay silent, never block Claude
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception:
        sys.exit(0)
